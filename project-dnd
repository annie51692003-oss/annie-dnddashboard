<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>annie-dnddashboard</title>

  <style>
    body{
      font-family: Arial, sans-serif;
      background:#f5f5f5;
      padding:30px;
    }

    .card{
      background:white;
      border-radius:12px;
      padding:20px;
      margin-bottom:12px;
      box-shadow:0 2px 6px rgba(0,0,0,.1);
    }

    .title{
      color:#666;
      font-size:14px;
    }

    .value{
      font-size:32px;
      font-weight:bold;
      margin-top:8px;
    }
  </style>
</head>

<body>

  <div class="card">
    <div class="title">📢 本月廣告費</div>
    <div class="value">$1,250,000</div>
  </div>

  <div class="card">
    <div class="title">📈 MoM</div>
    <div class="value">+15.2%</div>
  </div>

  <div class="card">
    <div class="title">📂 新案件數</div>
    <div class="value">128</div>
  </div>

</body>
</html>
